# ============================================================================
# B1Admin Production Dockerfile
# ============================================================================
# Multi-stage build for optimized production deployment
# ============================================================================

# Stage 1: Build the React application
FROM node:22-alpine AS builder

WORKDIR /app

# Copy package files and scripts for postinstall
COPY package.json package-lock.json ./
COPY scripts ./scripts

# Install dependencies
RUN npm ci --silent --legacy-peer-deps

# Force local API domains in bundled dependency defaults
RUN find node_modules/@churchapps -type f -name "*.js" -exec sed -i \
  -e 's#https://api\.churchapps\.org#/api#g' \
  -e 's#https://api\.staging\.churchapps\.org#/api#g' \
  -e 's#https://api\.demo\.churchapps\.org#/api#g' \
  -e 's#https://askapi\.churchapps\.org#/api/ask#g' \
  -e 's#https://askapi\.staging\.churchapps\.org#/api/ask#g' \
  -e 's#https://askapi\.demo\.churchapps\.org#/api/ask#g' \
  -e 's#https://content\.churchapps\.org#/api/content#g' \
  -e 's#https://content\.staging\.churchapps\.org#/api/content#g' \
  -e 's#https://democontent\.churchapps\.org#/api/content#g' \
  -e 's#wss://socket\.churchapps\.org#wss://admin.lifereformationcentre.org/ws#g' \
  -e 's#wss://socket\.staging\.churchapps\.org#wss://admin.lifereformationcentre.org/ws#g' \
  -e 's#wss://socket\.demo\.churchapps\.org#wss://admin.lifereformationcentre.org/ws#g' {} +

# Copy source code
COPY . .

# Build arguments for environment-specific configuration
ARG REACT_APP_STAGE
ARG REACT_APP_ATTENDANCE_API
ARG REACT_APP_GIVING_API
ARG REACT_APP_MEMBERSHIP_API
ARG REACT_APP_CONTENT_API
ARG REACT_APP_MESSAGING_API
ARG REACT_APP_DOING_API
ARG REACT_APP_REPORTING_API
ARG REACT_APP_CONTENT_ROOT
ARG REACT_APP_MESSAGING_API_SOCKET
ARG REACT_APP_B1_WEBSITE_URL
ARG REACT_APP_B1_ADMIN_URL
ARG REACT_APP_LESSONS_URL
ARG REACT_APP_GOOGLE_ANALYTICS

# Set environment variables for build
ENV REACT_APP_STAGE=$REACT_APP_STAGE
ENV REACT_APP_ATTENDANCE_API=$REACT_APP_ATTENDANCE_API
ENV REACT_APP_GIVING_API=$REACT_APP_GIVING_API
ENV REACT_APP_MEMBERSHIP_API=$REACT_APP_MEMBERSHIP_API
ENV REACT_APP_CONTENT_API=$REACT_APP_CONTENT_API
ENV REACT_APP_MESSAGING_API=$REACT_APP_MESSAGING_API
ENV REACT_APP_DOING_API=$REACT_APP_DOING_API
ENV REACT_APP_REPORTING_API=$REACT_APP_REPORTING_API
ENV REACT_APP_CONTENT_ROOT=$REACT_APP_CONTENT_ROOT
ENV REACT_APP_MESSAGING_API_SOCKET=$REACT_APP_MESSAGING_API_SOCKET
ENV REACT_APP_B1_WEBSITE_URL=$REACT_APP_B1_WEBSITE_URL
ENV REACT_APP_B1_ADMIN_URL=$REACT_APP_B1_ADMIN_URL
ENV REACT_APP_LESSONS_URL=$REACT_APP_LESSONS_URL
ENV REACT_APP_GOOGLE_ANALYTICS=$REACT_APP_GOOGLE_ANALYTICS

# Run postinstall to copy language files
RUN npm run postinstall

# Build the application
RUN npm run build

# Patch compiled JavaScript to replace B1.Church and Lessons.church labels and URLs
RUN PORTAL_URL=${REACT_APP_B1_WEBSITE_URL:-https://portal.lifereformationcentre.org} && \
    LESSONS_URL=${REACT_APP_LESSONS_URL:-https://lessons.lifereformationcentre.org} && \
    ADMIN_URL=${REACT_APP_B1_ADMIN_URL:-https://admin.lifereformationcentre.org} && \
    find dist/assets -type f -name "*.js" -exec sed -i \
      -e 's/label:"B1\.Church"/label:"Portal"/g' \
      -e 's/label:"Lessons\.church"/label:"Lessons"/g' \
      -e "s#appName===\"B1\.church\"#appName===\"Portal\"#g" \
      -e "s#appName===\"Lessons\.church\"#appName===\"Lessons\"#g" \
      -e "s#https://[^\"]*\.b1\.church#${PORTAL_URL}#g" \
      -e "s#http://[^\"]*\.b1\.church#${PORTAL_URL}#g" \
      -e "s#https://lessons\.church#${LESSONS_URL}#g" \
      -e "s#http://lessons\.church#${LESSONS_URL}#g" {} + && \
    find dist/assets -type f -name "*.js" -exec sed -i \
      -e "s#B1AdminRoot=\"${PORTAL_URL}\"#B1AdminRoot=\"${ADMIN_URL}\"#g" {} +

# Stage 2: Serve with Nginx
FROM nginx:alpine

# Copy custom nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Add healthcheck
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1

# Expose port 80
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
